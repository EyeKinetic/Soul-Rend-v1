# Copy this file to .env and fill in your actual values
# .env is gitignored and MUST NEVER be committed to git

VITE_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here
VITE_APPWRITE_DATABASE_ID=your_database_id_here
VITE_APPWRITE_BUCKET_ID=your_bucket_id_here
VITE_COLLECTION_ANNOUNCEMENTS=your_announcements_collection_id
VITE_COLLECTION_EVENTS=your_events_collection_id
VITE_COLLECTION_PATCH_NOTES=your_patch_notes_collection_id
VITE_COLLECTION_INFORMATION=your_information_collection_id
